# ── Required Secrets ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/aperti

# JWT signing key — generate with: openssl rand -base64 64
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Express session secret — generate with: openssl rand -base64 64
SESSION_SECRET=change-me-in-production-use-a-long-random-string

# ── AI Integration ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional / Environment ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# Restrict CORS in production — comma-separated list of allowed origins
# Leave unset in development to allow all origins
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Commit hash for build info (set automatically in CI/CD)
# COMMIT_HASH=abc1234

# Admin seeding (auto-created on first startup if accounts table is empty)
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=change-me

# ── Email (optional — for password reset, notifications) ───────────────────
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@yourdomain.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@yourdomain.com

# ── Storage (optional — for file uploads) ──────────────────────────────────
# STORAGE_BUCKET=your-s3-bucket
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
