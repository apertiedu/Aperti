# ─────────────────────────────────────────────────────────────────────────────
# Aperti Environment Variables — copy to .env and fill in values
# NEVER commit .env to version control
# Generate random secrets with: openssl rand -base64 48
# ─────────────────────────────────────────────────────────────────────────────

# ── Required (server exits on startup if missing) ────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/aperti
PORT=3001
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# ── Recommended ───────────────────────────────────────────────────────────────
SESSION_SECRET=another-long-random-secret
NODE_ENV=development

# ── AI (at least one key required for AI features) ────────────────────────────

# Option A: NVIDIA NIM (current default on Replit)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=openai/gpt-oss-20b

# Option B: Standard OpenAI
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Option C: Replit AI Integration (auto-provisioned on Replit — do not set manually)
# AI_INTEGRATIONS_OPENAI_API_KEY=<set by Replit>
# AI_INTEGRATIONS_OPENAI_BASE_URL=<set by Replit>

# ── CORS (comma-separated origins; leave unset to allow all in dev) ────────────
# ALLOWED_ORIGINS=https://app.aperti.ai,https://aperti.ai

# ── Web Push Notifications ────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@aperti.app

# ── LiveKit (live classes) ────────────────────────────────────────────────────
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# ── InstaPay / manual payments ───────────────────────────────────────────────
INSTAPAY_PHONE=
INSTAPAY_NAME=

# ── Deployment ────────────────────────────────────────────────────────────────
# APP_URL=https://your-domain.com
# COMMIT_HASH=abc1234  (set automatically in CI/CD)

# ── Note: Email is admin-assisted in-app flow (no SMTP required) ──────────────
# Password reset requests are handled by admins via /api/admin/password-resets
