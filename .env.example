# ── Database ─────────────────────────────────────────────────────────────────
# Replit PostgreSQL (auto-provided as secrets in the Replit environment)
DATABASE_URL=postgresql://user:password@host:5432/dbname
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=yourpassword
PGDATABASE=aperti

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=generate-a-64-char-hex-secret-here
SESSION_SECRET=generate-a-strong-session-secret-here

# ── Server ports ──────────────────────────────────────────────────────────────
PORT=5000
API_PORT=3001

# ── AI / OpenAI ───────────────────────────────────────────────────────────────
# On Replit: set via Settings → Integrations → OpenAI (auto-injects OPENAI_API_KEY)
# On other hosts: set a standard OpenAI key
OPENAI_API_KEY=sk-your-openai-api-key-here
# Optional overrides — leave unset to use OpenAI defaults (gpt-4o)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ── Push notifications (VAPID) ────────────────────────────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@yourdomain.com
