# ── Database ─────────────────────────────────────────────────────────────────
# Replit PostgreSQL (auto-provided as secrets in the Replit environment)
DATABASE_URL=postgresql://user:password@host:5432/dbname
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=yourpassword
PGDATABASE=aperti

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=generate-a-64-char-hex-secret-here
SESSION_SECRET=generate-a-strong-session-secret-here

# ── Server ports ──────────────────────────────────────────────────────────────
PORT=5000
API_PORT=3001

# ── AI / OpenAI-compatible provider ──────────────────────────────────────────
# Using NVIDIA NIM endpoint (compatible with OpenAI SDK)
OPENAI_API_KEY=nvapi-your-key-here
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=meta/llama-3.3-70b-instruct

# ── Push notifications (VAPID) ────────────────────────────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@yourdomain.com
