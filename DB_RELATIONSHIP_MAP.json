  "core_workflow_chains": {
    "Teacher → Course → Unit → Topic → Lesson": [
      "accounts (role=teacher)",
      "  → subjects (teacher_account_id)",
      "  → teacher_courses (teacher_account_id, subject_id)",
      "     → course_units (course_id)",
      "        → course_topics (unit_id)",
      "           → course_lessons_map (topic_id)",
      "              → lesson_content (content_id)",
      "  → lessons (teacher_account_id, subject_id)"
    ],
    "Account → Student → Attendance → Audit": [
      "accounts (role=student)",
      "  → students (account_id, teacher_account_id)",
      "     → attendance (student_id, session_id→lessons.id)",
      "        → attendance_audit (student_id, lesson_id) [standalone audit log]"
    ],
    "Parent → GuardianLink → Student": [
      "accounts (role=parent)",
      "  → guardian_links (parent_account_id, student_id)",
      "     → students.id"
    ],
    "Teacher → Exam → Question → Mark": [
      "exams (teacher_account_id, subject_id)",
      "  → exam_questions (exam_id)",
      "     → student_marks (exam_id, question_id, student_id)",
      "     → mark_schemes (exam_question_id)"
    ],
    "Teacher → Homework → Submission → Review": [
      "homework (teacher_account_id, subject_id)",
      "  → homework_submissions (homework_id, student_id)",
      "  → snapgrade_submissions (homework_id, student_id)",
      "     → peer_reviews (submission_id, reviewer_id)"
    ],
    "Student → Flashcard Progress → Mastery": [
      "flashcard_decks (teacher_account_id)",
      "  → flashcard_items (deck_id)",
      "     → flashcard_progress (card_id, student_id)"
    ],
    "Account → Subscription → Payment": [
      "subscription_plans",
      "  → subscriptions (account_id, plan_id)",
      "     → payment_transactions (subscription_id, user_id)",
      "     → billing_invoices (subscription_id, user_id)"
    ]
  }
}