modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["mailutils", "pnpm"]

[userenv]

[userenv.shared]
PORT = "5000"
BASE_PATH = "/"
API_PORT = "3001"
VAPID_PUBLIC_KEY = "BGM-42Vz7uBZB3D7uK3EQfLiXXzJgcwqVPLqTMSACCAczZFu0f6zJUd6AIlVmFtAM3fAzFyIhrIjG1E-rOsH5ZY"
VAPID_SUBJECT = "mailto:admin@aperti.app"
OPENAI_BASE_URL = "https://integrate.api.nvidia.com/v1"
OPENAI_MODEL = "openai/gpt-oss-20b"
JWT_SECRET = "6AiU5GnYRcCKNDdsn_ErbGgQyb8vdPuqumXYSkDz0WpXcLvfeGRiGVPWclUQLQmS"

[userenv.development]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/aperti && pnpm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && PORT=3001 pnpm run dev"
waitForPort = 3001

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 4983
externalPort = 5173
exposeLocalhost = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081
exposeLocalhost = true

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 21664
externalPort = 3002

[[ports]]
localPort = 21665
externalPort = 4200

[deployment]
deploymentTarget = "autoscale"
run = ["node", "artifacts/api-server/dist/index.mjs"]
build = ["pnpm", "run", "build"]
